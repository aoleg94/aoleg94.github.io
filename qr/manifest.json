{
  "name": "QR — text to QR code",
  "short_name": "QR",
  "description": "Generate a QR code from text, entirely in your browser.",
  "start_url": "/qr/",
  "scope": "/qr/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#1a1a1a",
  "theme_color": "#1a1a1a",
  "icons": [
    {
      "src": "/qr/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/qr/",
    "method": "GET",
    "params": {
      "text": "text",
      "url": "url"
    }
  }
}
